{
  "name": "yotube",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.mjs",
  "description": "Turn YouTube links into audio cards for Yoto",
  "scripts": {
    "postinstall": "node scripts/install-ytdlp.mjs",
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "desktop:install": "node scripts/install-ytdlp-desktop.mjs",
    "desktop:build": "node scripts/build-desktop.mjs",
    "desktop:dev": "npm run desktop:install && electron .",
    "desktop:package": "npm run desktop:install && npm run desktop:build && electron-forge package",
    "desktop:make": "npm run desktop:install && npm run desktop:build && electron-forge make",
    "lint": "eslint",
    "test": "vitest run"
  },
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron/fuses": "^2.1.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
