{
  "name": "yotube",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "lint": "eslint",
    "test": "vitest run",
    "electron": "electron .",
    "electron:build": "next build && PYTHON_PATH=\"$PWD/build/python3-dmg-wrapper.sh\" electron-builder",
    "electron:dist": "next build && PYTHON_PATH=\"$PWD/build/python3-dmg-wrapper.sh\" electron-builder --publish never"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "dev.alexmcc.yotube",
    "productName": "Yotube",
    "files": [
      "electron/**/*",
      "build/icon.png",
      ".next/**/*",
      "public/**/*",
      "next.config.ts",
      "package.json",
      "node_modules/**/*"
    ],
    "afterSign": "build/afterSign.js",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "identity": null
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility"
    }
  }
}
